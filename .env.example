# Auth Service
AUTH_SERVICE_DATABASE_URL=postgresql://postgres:Yourpassword@localhost/healthai
AUTH_SERVICE_SECRET_KEY=your-secret-key-change-in-production

# Report Service
REPORT_SERVICE_DATABASE_URL=postgresql://postgres:Yourpassword@localhost/healthai
REPORT_SERVICE_AWS_ACCESS_KEY_ID=your-aws-access-key
REPORT_SERVICE_AWS_SECRET_ACCESS_KEY=your-aws-secret-key
REPORT_SERVICE_AWS_REGION=us-east-1
REPORT_SERVICE_S3_BUCKET=ai-health-reports

# AI Service
AI_SERVICE_OLLAMA_URL=http://localhost:11434/api/generate
AI_SERVICE_OLLAMA_MODEL=llama2

# Frontend
REACT_APP_AUTH_URL=http://localhost:8000/api/auth
REACT_APP_API_URL=http://localhost:8001/api
REACT_APP_AI_URL=http://localhost:8002/api/ai
